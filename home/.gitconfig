[user]
	name = Tom George
	email = tomgeorge1@btinternet.com
[fetch]
	prune = true
[pull]
	rebase = true
[diff]
	algorithm = histogram
[branch]
	sort = -committerdate
[tag]
	sort = version:refname
[push]
	autoSetupRemote = true
[alias]
	clean-merged = !git branch --merged main | grep -vE \"^\\*|^\\s*(main|master)\\s*$\" | xargs -r git branch -d
